# Convex (from `npx convex dev` or Convex dashboard)
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Optional: set in Vercel for `npm run build:vercel` — deploys Convex during build
# CONVEX_DEPLOY_KEY=

# Same random string in Vercel and Convex dashboard — protects Convex queries/mutations from the MCP layer
BRIDGE_SECRET=

# Shared ingest secret: Vercel env + Convex env + GitHub Actions (for POST /api/ingest)
INGEST_SECRET=

# Bearer token for /api/mcp — required on Vercel/production (see app/api/mcp/route.ts)
MCP_BEARER_TOKEN=

# Optional: Kitchen V2 API key — enables MCP tool send_to_poke (POST /api/v1/inbound/api-message)
# https://poke.com/docs/api
POKE_API_KEY=

# Optional: "View on GitHub" on the landing page
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/HKTITAN/kheMind

# No OpenAI or other embedding API keys in Convex/Vercel — ingestion stores text only;
# agents handle semantic work on retrieved snippets.
